{
  "version": 2,
  "builds": [
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/search",
      "dest": "api/search.py"
    },
    {
      "src": "/api/trending",
      "dest": "api/trending.py"
    },
    {
      "src": "/api/song",
      "dest": "api/song.py"
    },
    {
      "src": "/api/artist",
      "dest": "api/artist.py"
    },
    {
      "src": "/api",
      "dest": "api/index.py"
    },
    {
      "src": "/",
      "dest": "api/index.py"
    }
  ]
}
